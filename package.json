{
  "name": "pinmy",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:push": "pnpm --filter @pinmy/db db:push",
    "db:studio": "pnpm --filter @pinmy/db db:studio",
    "start": "pnpm --filter @pinmy/api start"
  }
}
